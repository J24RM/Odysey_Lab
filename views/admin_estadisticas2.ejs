<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8" />
  <title>Estadísticas de Pedidos</title>
  <link rel="stylesheet" href="/style_admin_estadisticas2.css" />
</head>

<body class="font-sans bg-bgmain m-0 flex flex-col min-h-screen" style="background-color: #f4f6f9;">

  <!-- HEADER -->
  <header
    class="fixed top-0 left-0 right-0 h-[70px] bg-ppgbluelight flex items-center justify-between px-7 z-[100] border-b border-[#c9ddf5] shadow-[0_2px_8px_rgba(0,91,171,0.08)] bg-white">
    <div class="logo-area">
      <img src="/img/ppg-logo.svg" alt="Logo PPG" class="h-[44px] block">
    </div>

    <!-- BUSCADOR -->
    <div class="flex-1 max-w-[520px] mx-8 search-bar">
      <select onchange="window.location.href = this.value"
        class="w-full py-[10px] px-5 border-[1.5px] border-[#b8cfe8] rounded-[50px] font-sans text-[15px] bg-white text-textdark outline-none transition-colors duration-200 focus:border-[#005bab]">
        <option value="/admin_estadisticas">Estadísticas generales</option>
        <option value="/admin_estadisticas2" selected>Estadísticas de pedidos</option>
      </select>
    </div>

    <!-- CERRAR SESIÓN -->
    <div class="flex items-center gap-[10px]">
      <a href="/logout"
        class="inline-flex items-center justify-center py-2 px-[14px] rounded-full border border-[#b8cfe8] bg-white text-[#005bab] text-[14px] font-bold no-underline transition-all hover:bg-[#005bab] hover:text-white hover:border-[#005bab]">Cerrar
        sesión</a>
      <div class="w-[42px] h-[42px] rounded-full flex items-center justify-center cursor-pointer overflow-hidden">
        <img src="/img/iconoPerfil.png" alt="Usuario" class="w-full h-full object-cover">
      </div>
    </div>
  </header>

  <!-- SIDEBAR -->
  <div class="w-[220px] h-[calc(100vh-70px)] bg-[#252f3d] py-5 fixed top-[70px] left-0">
    <ul class="list-none p-0 m-0">
      <li class="my-5"><a href="/admin_home"
          class="text-white no-underline text-lg block py-[10px] px-5 hover:bg-white/20 hover:rounded-md transition-colors">Inicio</a>
      </li>
      <li class="my-5"><a href="/admin_estadisticas"
          class="text-white no-underline text-lg block py-[10px] px-5 bg-white/20 rounded-md transition-colors">Estadísticas</a>
      </li>
      <li class="my-5"><a href="/admin_historial"
          class="text-white no-underline text-lg block py-[10px] px-5 hover:bg-white/20 hover:rounded-md transition-colors">Historial
          de órdenes</a></li>
      <li class="my-5"><a href="/admin_clientes"
          class="text-white no-underline text-lg block py-[10px] px-5 hover:bg-white/20 hover:rounded-md transition-colors">Clientes</a>
      </li>
    </ul>
  </div>

  <!-- MAIN CONTENT -->
  <main class="main ml-[240px] pt-[90px] px-[30px] pb-5">

    <h1 class="page-title">ESTADÍSTICAS DE PEDIDOS</h1>

    <% if (!dbConnected) { %>
      <div
        style="background-color: #fef08a; border-left: 4px solid #eab308; color: #a16207; padding: 16px; margin-bottom: 24px;">
        <p style="font-weight: bold; margin: 0 0 5px 0;">Aviso</p>
        <p style="margin: 0;">No se ha conectado Supabase. Mostrando datos vacíos. Configura tu `.env` para ver datos
          reales.</p>
      </div>
      <% } %>

        <!-- FILTER ROW -->
        <div class="filter-row">
          <select class="filter-select">
            <option>Estadísticas de pedidos</option>
          </select>
          <select class="filter-select">
            <option>Semanales</option>
            <option>Mensuales</option>
          </select>
        </div>

        <!-- ====== WEEKLY ORDERS CARD ====== -->
        <div class="card">
          <p class="card__label">ORDENES SEMANALES:</p>
          <div class="orders-chart">
            <!-- Bar Chart -->
            <% const maxVal=Math.max(...diasSemana, 1); %> <!-- Prevenir div 0 -->
              <div class="chart-area">
                <div class="bar-group">
                  <div class="bar"
                    style="height: <%= Math.round((diasSemana[0] / maxVal) * 160) %>px; min-height: 10px;"></div>
                  <span class="bar-label">Lunes</span>
                </div>
                <div class="bar-group">
                  <div class="bar"
                    style="height: <%= Math.round((diasSemana[1] / maxVal) * 160) %>px; min-height: 10px;"></div>
                  <span class="bar-label">Martes</span>
                </div>
                <div class="bar-group">
                  <div class="bar"
                    style="height: <%= Math.round((diasSemana[2] / maxVal) * 160) %>px; min-height: 10px;"></div>
                  <span class="bar-label">Miércoles</span>
                </div>
                <div class="bar-group">
                  <div class="bar"
                    style="height: <%= Math.round((diasSemana[3] / maxVal) * 160) %>px; min-height: 10px;"></div>
                  <span class="bar-label">Jueves</span>
                </div>
                <div class="bar-group">
                  <div class="bar"
                    style="height: <%= Math.round((diasSemana[4] / maxVal) * 160) %>px; min-height: 10px;"></div>
                  <span class="bar-label">Viernes</span>
                </div>
              </div>

              <!-- Data Table -->
              <table class="data-table">
                <tbody>
                  <tr>
                    <td>LUNES</td>
                    <td>
                      <%= diasSemana[0] %> pedidos
                    </td>
                  </tr>
                  <tr>
                    <td>MARTES</td>
                    <td>
                      <%= diasSemana[1] %> pedidos
                    </td>
                  </tr>
                  <tr>
                    <td>MIÉRCOLES</td>
                    <td>
                      <%= diasSemana[2] %> pedidos
                    </td>
                  </tr>
                  <tr>
                    <td>JUEVES</td>
                    <td>
                      <%= diasSemana[3] %> pedidos
                    </td>
                  </tr>
                  <tr>
                    <td>VIERNES</td>
                    <td>
                      <%= diasSemana[4] %> pedidos
                    </td>
                  </tr>
                </tbody>
              </table>
          </div>
        </div>

        <!-- ====== PRODUCTS MOST ORDERED ====== -->
        <div class="card">
          <p class="card__label">PRODUCTOS MÁS PEDIDOS SEMANALMENTE:</p>

          <% if (productosSemana && productosSemana.length> 0) { %>
            <% productosSemana.forEach(producto=> { %>
              <div class="product-row">
                <div class="product-img">
                  <% if (producto.img) { %>
                    <img src="<%= producto.img %>" alt="<%= producto.nombre %>" />
                    <% } else { %>
                      <div style="font-size: 32px;">📦</div>
                      <% } %>
                </div>
                <div class="product-info">
                  <h4>
                    <%= producto.nombre %> &nbsp; <%= producto.desc %>
                  </h4>
                </div>
                <div class="product-price">
                  <p class="price-main">
                    <%= producto.precio ? '$ ' + producto.precio : 'N/A' %>
                  </p>
                </div>
              </div>
              <% }); %>
                <% } else { %>
                  <p style="color: #6b7280; font-size: 14px;">No hay productos pedidos esta semana.</p>
                  <% } %>

        </div>

  </main>

</body>

</html>