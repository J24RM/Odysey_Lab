<!DOCTYPE html>
<html lang="es">

<head>
<meta charset="UTF-8" />
<title>Estadísticas por Sucursal</title>
<script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
    * {
        font-family: 'Public Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }
</style>
</head>

<body class="bg-gray-50">

<%- include('partials/header.ejs') %>

<%- include('partials/sidebar.ejs') %>

<main class="ml-48 pt-2 px-10 pb-9 flex-1 min-h-[calc(100vh-70px)]">

    <!-- Tabs -->
    <div class="flex gap-1 border-b-2 border-gray-200 mb-6">
        <a href="/admin/stats" class="tab-link px-5 py-2.5 text-sm font-semibold text-gray-500 hover:text-gray-800 transition-colors border-b-2 border-transparent -mb-[2px]" data-tab="/admin/stats">Generales</a>
        <a href="/admin/stats/sucursales" class="tab-link px-5 py-2.5 text-sm font-semibold text-gray-500 hover:text-gray-800 transition-colors border-b-2 border-transparent -mb-[2px]" data-tab="/admin/stats/sucursales">Sucursales</a>
        <a href="/admin/stats/productos" class="tab-link px-5 py-2.5 text-sm font-semibold text-gray-500 hover:text-gray-800 transition-colors border-b-2 border-transparent -mb-[2px]" data-tab="/admin/stats/productos">Productos</a>
    </div>

    <div class="bg-white rounded-[14px] p-6 shadow-[0_4px_16px_rgba(0,0,0,0.07)]">
        <p class="text-[13px] font-bold text-gray-400 tracking-wide mb-6 uppercase">Sucursales con más pedidos confirmados</p>

        <% if (!topSucursales || topSucursales.length === 0) { %>
            <div class="flex flex-col items-center justify-center py-20 text-center">
                <div class="text-5xl mb-4">📊</div>
                <p class="text-gray-400 text-sm">Aún no hay órdenes confirmadas con sucursal asignada.</p>
            </div>
        <% } else { %>
        <%
            const CL = 70, CR = 875, CT = 50, CB = 310;
            const CW = CR - CL;
            const CH = CB - CT;
            const n = topSucursales.length;
            const gw = CW / n;
            const bw = Math.max(14, Math.min(26, gw * 0.28));
            const gap = 5;

            const maxOrd = Math.max(...topSucursales.map(s => s.total_ordenes));
            const maxVen = Math.max(...topSucursales.map(s => s.total_ventas));

            function niceMax(v) {
                if (v <= 0) return 1;
                const exp = Math.floor(Math.log10(v));
                const mag = Math.pow(10, exp);
                for (const f of [1, 2, 5, 10]) {
                    if (v <= f * mag) return f * mag;
                }
                return 10 * mag;
            }

            const amOrd = niceMax(maxOrd);
            const amVen = niceMax(maxVen);

            function fmtPeso(v) {
                if (v >= 1000000) return '$' + (v / 1000000).toFixed(1) + 'M';
                if (v >= 1000) return '$' + Math.round(v / 1000) + 'K';
                return '$' + Math.round(v);
            }

            const tickFracs = [0, 0.25, 0.5, 0.75, 1.0];

            // Ticks enteros únicos para el eje de pedidos
            const ordStep = Math.max(1, Math.ceil(amOrd / 5));
            const ordTickVals = [];
            for (let v = 0; v <= amOrd; v += ordStep) ordTickVals.push(v);
            if (ordTickVals[ordTickVals.length - 1] !== amOrd) ordTickVals.push(amOrd);
        %>

        <svg viewBox="0 0 960 500" width="100%">

            <!-- Grid lines -->
            <% tickFracs.forEach(t => {
                const gy = Math.round(CB - CH * t);
            %>
                <line x1="<%= CL %>" y1="<%= gy %>" x2="<%= CR %>" y2="<%= gy %>"
                      stroke="#f3f4f6" stroke-width="1"/>
            <% }) %>

            <!-- Axis lines -->
            <line x1="<%= CL %>" y1="<%= CT %>" x2="<%= CL %>" y2="<%= CB %>" stroke="#e5e7eb" stroke-width="1.5"/>
            <line x1="<%= CR %>" y1="<%= CT %>" x2="<%= CR %>" y2="<%= CB %>" stroke="#e5e7eb" stroke-width="1.5"/>
            <line x1="<%= CL %>" y1="<%= CB %>" x2="<%= CR %>" y2="<%= CB %>" stroke="#e5e7eb" stroke-width="1.5"/>

            <!-- Left Y axis: pedidos (enteros únicos) -->
            <% ordTickVals.forEach(val => {
                const ty = Math.round(CB - (val / amOrd) * CH);
            %>
                <text x="<%= CL - 8 %>" y="<%= ty + 4 %>" text-anchor="end" font-size="10" fill="#9ca3af"><%= val %></text>
            <% }) %>
            <text x="<%= CL - 42 %>" y="<%= Math.round((CT + CB) / 2) %>"
                  transform="rotate(-90, <%= CL - 42 %>, <%= Math.round((CT + CB) / 2) %>)"
                  text-anchor="middle" font-size="10" fill="#6b7280" font-weight="600">Pedidos</text>

            <!-- Right Y axis: ingresos -->
            <% tickFracs.forEach(t => {
                const ty = Math.round(CB - CH * t);
            %>
                <text x="<%= CR + 8 %>" y="<%= ty + 4 %>" text-anchor="start" font-size="10" fill="#9ca3af"><%= fmtPeso(amVen * t) %></text>
            <% }) %>
            <text x="<%= CR + 54 %>" y="<%= Math.round((CT + CB) / 2) %>"
                  transform="rotate(90, <%= CR + 54 %>, <%= Math.round((CT + CB) / 2) %>)"
                  text-anchor="middle" font-size="10" fill="#6b7280" font-weight="600">Ingresos (MXN)</text>

            <!-- Bars, value labels and X labels -->
            <% topSucursales.forEach((s, i) => {
                const groupX = CL + i * gw;
                const centerX = Math.round(groupX + gw / 2);
                const offset = (gw - bw * 2 - gap) / 2;
                const x1 = Math.round(groupX + offset);
                const x2 = x1 + bw + gap;

                const hOrd = Math.max(2, Math.round((s.total_ordenes / amOrd) * CH));
                const hVen = Math.max(2, Math.round((s.total_ventas / amVen) * CH));
                const yOrd = CB - hOrd;
                const yVen = CB - hVen;

                const labelOrdY = Math.max(CT + 12, yOrd - 5);
                const labelVenY = Math.max(CT + 12, yVen - 5);
            %>

                <!-- Orders bar (blue) -->
                <rect x="<%= x1 %>" y="<%= yOrd %>" width="<%= bw %>" height="<%= hOrd %>"
                      fill="#0050A0" rx="3">
                    <title><%= s.nombre_sucursal %> — <%= s.nombre_cuenta %>: <%= s.total_ordenes %> pedidos confirmados</title>
                </rect>
                <text x="<%= Math.round(x1 + bw / 2) %>" y="<%= labelOrdY %>"
                      text-anchor="middle" font-size="9" fill="#0050A0" font-weight="700">
                    <%= s.total_ordenes %>
                </text>

                <!-- Revenue bar (teal) -->
                <rect x="<%= x2 %>" y="<%= yVen %>" width="<%= bw %>" height="<%= hVen %>"
                      fill="#10b981" rx="3">
                    <title><%= s.nombre_sucursal %> — <%= s.nombre_cuenta %>: <%= fmtPeso(s.total_ventas) %> en ingresos</title>
                </rect>
                <text x="<%= Math.round(x2 + bw / 2) %>" y="<%= labelVenY %>"
                      text-anchor="middle" font-size="9" fill="#10b981" font-weight="700">
                    <%= fmtPeso(s.total_ventas) %>
                </text>

                <!-- X label: sucursal + cuenta (rotated -45°) -->
                <g transform="translate(<%= centerX %>, <%= CB + 14 %>) rotate(-45)">
                    <text x="0" y="0" text-anchor="end" font-size="9.5" fill="#374151"><%= s.nombre_sucursal %></text>
                    <text x="0" y="13" text-anchor="end" font-size="8.5" fill="#9ca3af"><%= s.nombre_cuenta %></text>
                </g>

            <% }) %>

            <!-- Legend -->
            <rect x="<%= CL %>" y="<%= CT - 30 %>" width="12" height="12" fill="#0050A0" rx="2"/>
            <text x="<%= CL + 16 %>" y="<%= CT - 20 %>" font-size="11" fill="#374151">Pedidos confirmados</text>
            <rect x="<%= CL + 150 %>" y="<%= CT - 30 %>" width="12" height="12" fill="#10b981" rx="2"/>
            <text x="<%= CL + 166 %>" y="<%= CT - 20 %>" font-size="11" fill="#374151">Ingresos totales (MXN)</text>

        </svg>
        <% } %>
    </div>

</main>

<%- include('partials/footer.ejs') %>

<script>
    const currentPath = window.location.pathname;
    document.querySelectorAll('.tab-link').forEach(tab => {
        if (tab.dataset.tab === currentPath) {
            tab.classList.add('border-blue-600', 'text-blue-600');
            tab.classList.remove('text-gray-500');
        }
    });
</script>

</body>

</html>
