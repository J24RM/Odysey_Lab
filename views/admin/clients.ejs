<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Clientes</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            font-family: 'Public Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }
    </style>
</head>

<body class="bg-gray-50">
    <%- include('partials/header.ejs') %>

    <div class="flex min-h-screen flex-col">
        <%- include('partials/sidebar.ejs') %>

        <!-- Main Content -->
        <main class="ml-48 pt-2 px-10 pb-9 flex-1">
            <section class="space-y-6">
                <h1 class="text-3xl font-extrabold text-gray-900">Clientes</h1>

                <!-- Toolbar -->
                <div class="flex items-center gap-4">
                    <div class="flex-1 relative">
                        <input id="searchInput" type="text" placeholder="Buscar Cliente" class="w-full px-5 py-2.5 border-2 border-gray-300 rounded-full text-sm font-medium focus:border-blue-600 focus:outline-none transition-colors" />
                    </div>
                    <button type="button" class="px-6 py-2.5 bg-white border-2 border-gray-300 rounded-lg font-semibold text-sm text-gray-900 hover:bg-gray-100 transition-all">
                        Filtrar
                    </button>
                </div>

                <!-- Clients Table -->
                <div class="bg-white rounded-2xl shadow-md overflow-hidden">
                    <!-- Table Header -->
                    <div class="grid grid-cols-4 gap-4 px-6 py-4 border-b-2 border-gray-200 bg-gray-50">
                        <span class="font-bold text-sm text-gray-700 uppercase tracking-wide">Perfil</span>
                        <span class="font-bold text-sm text-gray-700 uppercase tracking-wide">Nombre</span>
                        <span class="font-bold text-sm text-gray-700 uppercase tracking-wide">Correo Electrónico</span>
                        <span class="font-bold text-sm text-gray-700 uppercase tracking-wide">Última sesión</span>
                    </div>

                    <!-- Table Body -->
                    <div id="clientesBody" class="divide-y divide-gray-200">
                        <% if (clientes.length === 0) { %>
                            <p class="px-6 py-8 text-center text-gray-400 text-sm">No hay clientes registrados.</p>
                        <% } %>
                        <% clientes.forEach((cliente) => { %>
                            <a href="/admin/clients/<%= cliente.id_usuario %>"
                               class="cliente-row grid grid-cols-4 gap-4 px-6 py-4 items-center hover:bg-blue-50 transition-colors"
                               data-search="<%= (cliente.nombre || '') + ' ' + cliente.email %>">
                                <div class="w-10 h-10 rounded-full overflow-hidden bg-gray-200 flex-shrink-0">
                                    <img src="/img/iconoPerfil.png" alt="Perfil de cliente" class="w-full h-full object-cover">
                                </div>
                                <span class="font-semibold text-gray-900"><%= cliente.nombre || cliente.email %></span>
                                <span class="text-gray-600 text-sm"><%= cliente.email %></span>
                                <span class="text-gray-500 text-sm">N/A</span>
                            </a>
                        <% }); %>
                    </div>

                    <!-- Sin resultados (oculto por defecto) -->
                    <p id="noResults" class="hidden px-6 py-8 text-center text-gray-400 text-sm">
                        No se encontraron clientes con ese nombre o correo.
                    </p>
                </div>
            </section>
        </main>
    </div>

    <%- include('partials/footer.ejs') %>

    <script>
        const searchInput = document.getElementById('searchInput');
        const rows = document.querySelectorAll('.cliente-row');
        const noResults = document.getElementById('noResults');

        searchInput.addEventListener('input', function () {
            const query = this.value.toLowerCase().trim();
            let visibleCount = 0;

            rows.forEach(row => {
                const text = row.dataset.search.toLowerCase();
                const matches = text.includes(query);
                row.style.display = matches ? '' : 'none';
                if (matches) visibleCount++;
            });

            noResults.classList.toggle('hidden', visibleCount > 0 || query === '');
        });
    </script>

</body>
</html>
